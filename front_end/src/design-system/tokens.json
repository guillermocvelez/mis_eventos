{
  "$schema": "https://design-tokens.org",
  "name": "Mis Eventos - Design Tokens",
  "version": "1.0.0",
  "color": {
    "brand": {
      "navy": { "value": "#1E3A5F", "css": "--navy", "use": "Primario" },
      "navy-700": { "value": "#16304F", "css": "--navy-700", "use": "Primario hover" },
      "navy-900": { "value": "#102338", "css": "--navy-900", "use": "Primario profundo" },
      "blue": { "value": "#2B5797", "css": "--blue", "use": "Secundario / accion" },
      "blue-50": { "value": "#EAF1FA", "css": "--blue-50", "use": "Fondo suave azul" }
    },
    "surface": {
      "surface": { "value": "#D5E8F0", "css": "--surface", "use": "Superficie azul claro" },
      "surface-50": {
        "value": "#EEF6FA",
        "css": "--surface-50",
        "use": "Superficie azul muy claro"
      },
      "white": { "value": "#FFFFFF", "css": "--white" },
      "gray": { "value": "#F2F2F2", "css": "--gray", "use": "Filas alternas / paneles" },
      "gray-200": { "value": "#E7E9EC", "css": "--gray-200" },
      "gray-300": { "value": "#D7DBE0", "css": "--gray-300", "use": "Bordes de input" }
    },
    "status": {
      "green": { "value": "#1E7145", "css": "--green", "use": "Exito / publicado" },
      "green-50": { "value": "#E4F1EA", "css": "--green-50" },
      "orange": { "value": "#C55A11", "css": "--orange", "use": "Aviso / cancelado" },
      "orange-50": { "value": "#FBEADD", "css": "--orange-50" },
      "red": { "value": "#C0392B", "css": "--red", "use": "Peligro / eliminar" },
      "red-50": { "value": "#FBE7E4", "css": "--red-50" },
      "purple": { "value": "#5C3D91", "css": "--purple", "use": "Acento / sesiones" },
      "purple-50": { "value": "#EFEAF7", "css": "--purple-50" },
      "yellow": { "value": "#C99A06", "css": "--yellow", "use": "Aforo medio" },
      "yellow-50": { "value": "#FBF2D8", "css": "--yellow-50" }
    },
    "text": {
      "ink": { "value": "#1B2733", "css": "--ink", "use": "Texto principal" },
      "ink-2": { "value": "#46566A", "css": "--ink-2", "use": "Texto secundario" },
      "ink-3": { "value": "#7A8AA0", "css": "--ink-3", "use": "Texto terciario / placeholder" },
      "line": { "value": "#E4E8EE", "css": "--line", "use": "Divisores / bordes" }
    }
  },
  "radius": {
    "card": { "value": "8px", "css": "--r-card", "use": "Tarjetas y paneles" },
    "input": { "value": "6px", "css": "--r-input", "use": "Inputs y botones" },
    "pill": { "value": "24px", "css": "--r-pill", "use": "Badges y chips" }
  },
  "shadow": {
    "base": { "value": "0 2px 8px rgba(16,35,56,0.08)", "css": "--shadow" },
    "md": { "value": "0 6px 20px rgba(16,35,56,0.12)", "css": "--shadow-md" },
    "lg": { "value": "0 18px 50px rgba(16,35,56,0.22)", "css": "--shadow-lg" }
  },
  "typography": {
    "fontFamily": {
      "sans": {
        "value": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
        "css": "--font"
      },
      "mono": {
        "value": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace",
        "css": "--mono"
      }
    },
    "fontSize": {
      "display": { "value": "30px", "css": "--fs-display" },
      "h1": { "value": "20px", "css": "--fs-h1" },
      "h2": { "value": "18px", "css": "--fs-h2" },
      "h3": { "value": "16px", "css": "--fs-h3" },
      "body": { "value": "14px", "css": "--fs-body" },
      "sm": { "value": "13px", "css": "--fs-sm" },
      "xs": { "value": "12px", "css": "--fs-xs" },
      "2xs": { "value": "11px", "css": "--fs-2xs" }
    },
    "fontWeight": {
      "regular": { "value": 400, "css": "--fw-regular" },
      "medium": { "value": 500, "css": "--fw-medium" },
      "semibold": { "value": 600, "css": "--fw-semibold" },
      "bold": { "value": 700, "css": "--fw-bold" },
      "extra": { "value": 800, "css": "--fw-extra" }
    }
  },
  "spacing": {
    "1": { "value": "4px", "css": "--space-1" },
    "2": { "value": "8px", "css": "--space-2" },
    "3": { "value": "12px", "css": "--space-3" },
    "4": { "value": "16px", "css": "--space-4" },
    "5": { "value": "20px", "css": "--space-5" },
    "6": { "value": "24px", "css": "--space-6" },
    "7": { "value": "28px", "css": "--space-7" },
    "9": { "value": "36px", "css": "--space-9" }
  }
}
