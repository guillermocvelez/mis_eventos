# .gitignore para proyecto FastAPI + Vue.js + Docker Compose + PostgreSQL

# =========================
# Python / FastAPI
# =========================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo

# Entornos virtuales
venv/
.venv/
env/
ENV/
back_end/mis_eventos/

# Variables de entorno
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Cobertura y testing
.coverage
.coverage.*
htmlcov/
.pytest_cache/
coverage.xml
.tox/
.nox/

# MyPy
.mypy_cache/
.pyre/

# Ruff
.ruff_cache/

# FastAPI / Python tooling
.hypothesis/
.ipynb_checkpoints/
pip-wheel-metadata/
*.egg-info/
build/
develop-eggs/
eggs/
parts/
sdist/
var/
wheels/

# IDEs
.vscode/
.idea/

# Sistema operativo
.DS_Store
Thumbs.db

# =========================
# Node / Vue.js
# =========================
front_end/node_modules/
node_modules/

# Build Vue
dist/
.nuxt/
.output/

# Cache
.cache/
.npm/
.yarn/

# Logs npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Docker
# =========================
docker-compose.override.yml

# Archivos temporales de Docker
*.pid

# =========================
# PostgreSQL
# =========================
postgres_data/
pgdata/
db_data/

# Dumps
*.sql
*.dump
backup/

# =========================
# Archivos de desarrollo
